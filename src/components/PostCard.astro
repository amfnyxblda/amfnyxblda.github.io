---
import { canonicalizeCategorySlug, formatCategory } from "../lib/utils";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  author: string;
  slug: string;
  heroImage?: string;
  readingTime?: number;
  featured?: boolean;
  variant?: "default" | "compact" | "featured";
}

const {
  title,
  description,
  pubDate,
  category,
  author,
  slug,
  heroImage,
  readingTime,
  featured = false,
  variant = "default",
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const categorySlug = canonicalizeCategorySlug(category);
const categoryLabel = formatCategory(categorySlug);

const normalizedSlug = slug.startsWith("/") ? slug.slice(1) : slug;
const href = normalizedSlug.includes("/")
  ? `/${normalizedSlug}`
  : `/${categorySlug}/${normalizedSlug}`;
---

<article class={`post-card post-card--${variant} ${featured ? "post-card--featured" : ""}`}>
  {heroImage && variant !== "compact" && (
    <a href={href} class="post-card__image-wrap" tabindex="-1" aria-hidden="true">
      <img
        src={heroImage}
        alt={title}
        class="post-card__image"
        loading="lazy"
        decoding="async"
        width="800"
        height="450"
      />
    </a>
  )}

  <div class="post-card__body">
    <div class="post-card__meta">
      <a href={`/${categorySlug}`} class="tag tag--accent">{categoryLabel}</a>
      <span class="post-card__dot" aria-hidden="true">·</span>
      <time datetime={pubDate.toISOString()} class="post-card__date">{formattedDate}</time>
      {readingTime && (
        <>
          <span class="post-card__dot" aria-hidden="true">·</span>
          <span class="post-card__reading-time">{readingTime} min read</span>
        </>
      )}
    </div>

    <h2 class="post-card__title">
      <a href={href} class="post-card__title-link">{title}</a>
    </h2>

    {variant !== "compact" && (
      <p class="post-card__description">{description}</p>
    )}

    <div class="post-card__footer">
      <span class="post-card__author">{author}</span>
      <a href={href} class="post-card__read-link" aria-label={`Read: ${title}`}>
        Read →
      </a>
    </div>
  </div>
</article>

<style>
/* ── Base card ───────────────────────────────── */
.post-card {
  display: flex;
  flex-direction: column;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: box-shadow var(--transition), transform var(--transition);
}

.post-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

/* ── Image ───────────────────────────────────── */
.post-card__image-wrap {
  display: block;
  overflow: hidden;
  aspect-ratio: 16/9;
  background: var(--color-border-light);
}

.post-card__image {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.post-card:hover .post-card__image { transform: scale(1.03); }

/* ── Body ────────────────────────────────────── */
.post-card__body {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: var(--space-sm);
}

/* ── Meta ────────────────────────────────────── */
.post-card__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-sm);
  font-family: var(--font-mono);
  font-size: 0.7rem;
}

.post-card__dot { color: var(--color-ink-4); }

.post-card__date,
.post-card__reading-time {
  color: var(--color-ink-3);
}

/* ── Title ───────────────────────────────────── */
.post-card__title {
  font-size: 1.2rem;
  line-height: 1.3;
  font-weight: 600;
  margin: 0;
}

.post-card__title-link {
  color: var(--color-ink);
  transition: color var(--transition);
  text-decoration: none;
}

.post-card__title-link:hover { color: var(--color-accent); }

/* ── Description ─────────────────────────────── */
.post-card__description {
  font-size: 0.9rem;
  color: var(--color-ink-3);
  line-height: 1.6;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Footer ──────────────────────────────────── */
.post-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: var(--space-sm);
  border-top: 1px solid var(--color-border-light);
}

.post-card__author {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--color-ink-4);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.post-card__read-link {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--color-accent);
  letter-spacing: 0.04em;
  transition: gap var(--transition);
}

.post-card__read-link:hover { color: var(--color-ink); }

/* ── Featured variant ────────────────────────── */
.post-card--featured {
  border-color: var(--color-accent);
}

/* ── Compact variant (list row) ──────────────── */
.post-card--compact {
  flex-direction: row;
  align-items: center;
  border-radius: var(--radius-sm);
  padding: var(--space-md) var(--space-lg);
  gap: var(--space-md);
}

.post-card--compact .post-card__body {
  padding: 0;
  gap: 4px;
}

.post-card--compact .post-card__title {
  font-size: 1rem;
}

.post-card--compact .post-card__footer {
  border: none;
  padding: 0;
  margin-top: 2px;
}
</style>
