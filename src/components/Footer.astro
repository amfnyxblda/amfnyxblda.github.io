---
import { getCollection } from "astro:content";
import { canonicalizeCategorySlug, formatCategory } from "../lib/utils";

const year = new Date().getFullYear();

const posts = await getCollection("blog");
const categorySlugs = [...new Set(posts.map((post) => canonicalizeCategorySlug(post.id.split("/")[0])))].sort();

const categories = categorySlugs.map((slug) => ({
  href: `/${canonicalizeCategorySlug(slug)}`,
  label: formatCategory(slug),
}));
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="logo-mark">J</span>agapet
      </a>
      <p class="footer-tagline">
        Life is better with a little fur on your clothes and a lot of love in your house. Dive into our collection of hacks, reviews, and sanity-saving tips designed to make every day with your pet an adventure.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <h3 class="footer-nav-title">Categories</h3>
      <ul class="footer-links">
        {categories.map(cat => (
          <li><a href={cat.href} class="footer-link">{cat.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="footer-extra">
      <h3 class="footer-nav-title">Pages</h3>
      <ul class="footer-links">
          <li><a href="/"   class="footer-link">All Articles</a></li>
        <li><a href="/search" class="footer-link">Search</a></li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">© {year} Meridian. All rights reserved.</p>
      <!-- <p class="footer-made">Crafted with <a href="https://astro.build" target="_blank" rel="noopener" class="footer-link">Astro</a></p> -->
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--color-ink);
  color: rgba(255,255,255,0.55);
}

.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: var(--space-2xl);
  padding-top: var(--space-2xl);
  padding-bottom: var(--space-2xl);
}

.footer-logo {
  display: inline-flex;
  align-items: baseline;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.6rem;
  color: white;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-md);
  transition: color var(--transition);
}

.footer-logo:hover { color: var(--color-accent-2); }
.footer-logo .logo-mark { color: var(--color-accent-2); }

.footer-tagline {
  font-size: 0.9rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.45);
  margin: 0;
}

.footer-nav-title {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: var(--space-md);
  font-weight: 500;
}

.footer-links { display: flex; flex-direction: column; gap: var(--space-sm); }

.footer-link {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.55);
  transition: color var(--transition);
}

.footer-link:hover { color: white; }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
}

.footer-bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-lg);
  padding-bottom: var(--space-lg);
}

.footer-copy,
.footer-made {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.3);
  margin: 0;
}

@media (max-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }
  .footer-brand { grid-column: 1 / -1; }
}

@media (max-width: 480px) {
  .footer-inner { grid-template-columns: 1fr; }
  .footer-bottom-inner { flex-direction: column; gap: var(--space-sm); text-align: center; }
}
</style>
