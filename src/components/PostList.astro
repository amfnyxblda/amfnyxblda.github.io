---
import type { CollectionEntry } from 'astro:content';
import { formatCategory } from '../lib/utils';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---
<div id="article-list" class="blog-list">
  {posts.map((post) => {
    const category = post.slug.split('/')[0];
    return (
       <a href={`/${post.slug}/`} class="article-card">
          <div class="card-image">
              <img src={post.data.heroImage} alt="${item.title}">
          </div>
          <div class="card-content">
              <div>
                  <div class="card-meta">
                      <span>{formatCategory(category)}</span> • <span>{post.data.pubDate.toDateString()}</span>
                  </div>
                  <h2 class="card-title">{post.data.title}</h2>
                  <p class="card-excerpt">{post.data.description}</p>
              </div>
              {/* <a href={`/${post.slug}/`} class="read-more">Read Article &rarr;</a> */}
          </div>
      </a>
    );
  })}
</div>
<style>
/* Blog List (Vertical) */
.blog-list {
    display: flex;
    flex-direction: column;
    gap: 30px;
}
.article-card {
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: transform 0.2s;
    height: 220px; /* Fixed height for consistency */
    text-decoration: none;
    color: black;
}

.article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

.card-image {
    flex: 0 0 35%; /* Takes up 35% of width */
    position: relative;
    overflow: hidden;
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
}

.article-card:hover .card-image img {
    transform: scale(1.05);
}

.card-content {
    flex: 1;
    padding: 25px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.card-meta {
    font-size: 0.85rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
}

.card-title {
    font-size: 1.4rem;
    margin-bottom: 10px;
    color: var(--secondary-color);
    line-height: 1.3;
}

.card-excerpt {
    color: var(--text-color);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2; /* Limit to 3 lines */
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.read-more {
    display: inline-block;
    margin-top: 5px;
    text-decoration: none;
    color: var(--primary-color);
    font-weight: 600;
}

.read-more:hover {
    text-decoration: underline;
}
@media (max-width: 600px) {
  .article-card {
      flex-direction: column;
      height: auto;
  }
  .card-image {
      height: 200px;
  }
  .card-title {
      font-size: 1.2rem;
  }
}
</style>