---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  firstPageUrl?: string;
}

const {
  currentPage,
  totalPages,
  baseUrl,
  firstPageUrl = baseUrl,
} = Astro.props;

const prevUrl = currentPage > 1
  ? currentPage === 2
    ? firstPageUrl
    : `${baseUrl}/${currentPage - 1}`
  : null;

const nextUrl = currentPage < totalPages
  ? `${baseUrl}/${currentPage + 1}`
  : null;

// Build visible page numbers
const pages: (number | "...")[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (
    i === 1 ||
    i === totalPages ||
    (i >= currentPage - 1 && i <= currentPage + 1)
  ) {
    pages.push(i);
  } else if (
    (i === currentPage - 2 && i > 1) ||
    (i === currentPage + 2 && i < totalPages)
  ) {
    pages.push("...");
  }
}
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    <a
      href={prevUrl ?? undefined}
      class={`pagination__btn pagination__btn--prev ${!prevUrl ? "pagination__btn--disabled" : ""}`}
      aria-disabled={!prevUrl}
    >
      ← Prev
    </a>

    <div class="pagination__pages">
      {pages.map((p) =>
        p === "..." ? (
          <span class="pagination__ellipsis">…</span>
        ) : (
          <a
            href={p === 1 ? firstPageUrl : `${baseUrl}/${p}`}
            class={`pagination__page ${p === currentPage ? "pagination__page--active" : ""}`}
            aria-current={p === currentPage ? "page" : undefined}
          >
            {p}
          </a>
        )
      )}
    </div>

    <a
      href={nextUrl ?? undefined}
      class={`pagination__btn pagination__btn--next ${!nextUrl ? "pagination__btn--disabled" : ""}`}
      aria-disabled={!nextUrl}
    >
      Next →
    </a>
  </nav>
)}

<style>
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  margin-top: var(--space-2xl);
  flex-wrap: wrap;
}

.pagination__btn {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.5rem 1rem;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  color: var(--color-ink-2);
  transition: all var(--transition);
}

.pagination__btn:not(.pagination__btn--disabled):hover {
  border-color: var(--color-ink);
  background: var(--color-ink);
  color: white;
}

.pagination__btn--disabled {
  opacity: 0.35;
  pointer-events: none;
  cursor: default;
}

.pagination__pages {
  display: flex;
  align-items: center;
  gap: 4px;
}

.pagination__page {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px; height: 36px;
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--color-ink-2);
  border: 1.5px solid transparent;
  transition: all var(--transition);
}

.pagination__page:hover {
  border-color: var(--color-border);
  color: var(--color-ink);
}

.pagination__page--active {
  background: var(--color-ink);
  color: white;
  border-color: var(--color-ink);
}

.pagination__ellipsis {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  color: var(--color-ink-4);
  font-size: 0.85rem;
}
</style>
