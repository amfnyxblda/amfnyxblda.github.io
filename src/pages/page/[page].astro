---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from "../../components/Pagination.astro";
import { canonicalizeCategorySlug, formatCategory } from "../../lib/utils";

export const POSTS_PER_PAGE = 3;

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  
  const sorted = allPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  const totalPages = Math.ceil(sorted.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: {
      currentPage: i + 1,
      totalPages,
      pagePosts: sorted.slice(i * POSTS_PER_PAGE, (i + 1) * POSTS_PER_PAGE),
      totalPosts: sorted.length,
    },
  }));
}

// Fetch categories for the cloud on every paginated page
const allPosts = await getCollection('blog');
const allCategories = allPosts.map((post) => canonicalizeCategorySlug(post.id.split('/')[0]));
const categories = [...new Set(allCategories)];
const postPath = (postId: string) => {
  const [rawCategory, slug] = postId.split("/");
  return `/${canonicalizeCategorySlug(rawCategory)}/${slug}`;
};

const { currentPage, totalPages, pagePosts, totalPosts } = Astro.props;

const baseUrl = Astro.site?.toString() ?? Astro.url.origin;
const pageUrl = Astro.url.href;
const paginationSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Jagapet Articles - Page ${currentPage}`,
  description: `Page ${currentPage} of ${totalPages} for all Jagapet articles.`,
  url: pageUrl,
  isPartOf: {
    "@type": "CollectionPage",
    name: "Jagapet Articles",
    url: new URL("/page/1", baseUrl).toString(),
  },
  mainEntity: {
    "@type": "ItemList",
    itemListOrder: "https://schema.org/ItemListOrderDescending",
    numberOfItems: pagePosts.length,
    itemListElement: pagePosts.map((post, index) => ({
      "@type": "ListItem",
      position: (currentPage - 1) * POSTS_PER_PAGE + index + 1,
      url: new URL(postPath(post.id), baseUrl).toString(),
      name: post.data.title,
    })),
  },
};

function timeAgo(date: Date): string {
  const diff = Date.now() - date.getTime();
  const hours = Math.floor(diff / 3600000);
  const days  = Math.floor(diff / 86400000);
  if (hours < 1)  return "Just now";
  if (hours < 24) return `${hours} hr${hours > 1 ? "s" : ""} ago`;
  if (days < 7)   return `${days} day${days > 1 ? "s" : ""} ago`;
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---
<BaseLayout
  title={`Articles — Page ${currentPage}`}
  description={`Page ${currentPage} of ${totalPages} — all articles on Meridian.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(paginationSchema)} />
  <div class="blog-page">

    <!-- Category header -->
    <div class="cat-header">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/" class="breadcrumb__link">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/" class="breadcrumb__link">Articles</a>
        </nav>

        <div class="cat-header__inner">
          <div>
            <h1 class="cat-header__title">All Articles</h1>
             <p class="cat-header__desc">
              The full library of our blog posts. Dive into all topics, from latest trends to in-depth guides.
            </p>
            <!-- <span class="cat-header__count">
              {totalPosts} {totalPosts === 1 ? "article" : "articles"}
              {totalPages > 1 ? ` · Page ${currentPage} of ${totalPages}` : ""}
            </span> -->
          </div>
        </div>

        <!-- Other categories -->
        <nav class="cat-filter" aria-label="Other categories">
          <a href={`/page/${currentPage}`} class="filter-btn filter-btn--active">All</a>
          {categories.map((cat) => (
            <a
              href={`/${cat.toLowerCase().replace(/\s+/g, "-")}`}
              class={`filter-btn ${cat === 'ALL' ? "filter-btn--active" : ""}`}
            >
              {formatCategory(cat)}
            </a>
          ))}
          <a href="/search" class="filter-btn filter-btn--search" aria-label="Search articles">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </a>
        </nav>
      </div>
    </div>

    <!-- ── Main layout: list + sidebar ──────────── -->
    <div class="blog-layout">

      <!-- Article list -->
      <main class="blog-main" id="main-content">

        <!-- Article rows -->
        <div class="article-list">
          {pagePosts.map((post) => {
            const category = canonicalizeCategorySlug(post.id.split('/')[0]);
            const ago     = timeAgo(post.data.pubDate);
            return (
              <article class="article-row">
                <!-- Category label (vertical, left) -->
                <a href={`/${category}`} class="article-row__cat" aria-label={`Category: ${post.data.category}`}>
                  <span>{formatCategory(category).toUpperCase()}</span>
                </a>

                <!-- Thumbnail -->
                {post.data.heroImage && (
                  <a href={postPath(post.id)} class="article-row__thumb-wrap" tabindex="-1" aria-hidden="true">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      class="article-row__thumb"
                      loading="lazy"
                      decoding="async"
                      width="320"
                      height="200"
                    />
                    {post.data.featured && (
                      <span class="article-row__featured-badge">Featured</span>
                    )}
                  </a>
                )}

                <!-- Text -->
                <div class="article-row__body">
                  <div class="article-row__header"><span class="article-row__time">{ago}</span>
                  {post.data.readingTime && (
                      <>
                        <span class="article-row__meta-dot">&#x2022;</span>
                        <span class="article-row__read-time">{post.data.readingTime} min</span>
                      </>
                    )}
                  </div>
                  <h2 class="article-row__title">
                    <a href={postPath(post.id)} class="article-row__title-link">
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="article-row__desc">{post.data.description}</p>

                  <!-- Reactions / meta row -->
                  <div class="article-row__meta">
                    {/* <div class="article-row__reactions">
                      <span class="reaction">&#x1F525;</span>
                      <span class="reaction">&#x1F914;</span>
                      <span class="reaction-count">{Math.floor(Math.random() * 40) + 4}</span>
                    </div>
                    <span class="article-row__meta-dot">&#x2022;</span>
                    <a href={postPath(post.id)} class="article-row__comments">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                      </svg>
                      {Math.floor(Math.random() * 30) + 2}
                    </a> */}
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          baseUrl="/page"
          firstPageUrl="/page/1"
        />
      </main>

      <!-- Sidebar -->
      <aside class="blog-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-heading">Categories</h3>
          <ul class="sidebar-cats">
            {categories.map((cat) => {
              const count = allPosts.filter((p) => canonicalizeCategorySlug(p.id.split('/')[0]) === cat).length;
              return (
                <li>
                  <a href={`/${cat}`} class="sidebar-cat">
                    <span class="sidebar-cat__name">{formatCategory(cat)}</span>
                    {/* <span class="sidebar-cat__count">{count}</span> */}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>

        <!-- <div class="sidebar-section">
          <h3 class="sidebar-heading">Featured</h3>
          {allPosts.filter((p) => p.data.featured).slice(0, 4).map((post) => (
            <a href={postPath(post.id)} class="sidebar-featured">
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt="" class="sidebar-featured__img" width="60" height="60" loading="lazy" />
              )}
              <span class="sidebar-featured__title">{post.data.title}</span>
            </a>
          ))}
        </div> -->

        <div class="sidebar-section">
          <a href="/search" class="sidebar-search-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            Search articles
          </a>
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>

<style>
.page-header {
  padding-top: calc(80px + 1.5rem);
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-2xl) 0 var(--space-xl);
}
.page-kicker {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: var(--space-sm);
}
.page-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; margin-bottom: var(--space-sm); }
.page-desc { color: var(--color-ink-3); font-size: 1rem; margin: 0; }

.blog-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: var(--space-2xl);
  padding-top: var(--space-2xl);
  padding-bottom: var(--space-3xl);
  align-items: start;
}

.post-list { display: flex; flex-direction: column; gap: var(--space-lg); }

.blog-sidebar { position: sticky; top: calc(var(--nav-height) + var(--space-lg)); }

.sidebar-widget {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.sidebar-title {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink-4);
  margin-bottom: var(--space-sm);
  font-weight: 500;
}

.sidebar-link {
  font-size: 0.88rem;
  color: var(--color-accent);
  transition: color var(--transition);
}
.sidebar-link:hover { color: var(--color-ink); }

.sidebar-search-btn {
  display: block;
  padding: 0.65rem 1rem;
  background: var(--color-bg);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
  color: var(--color-ink-2);
  transition: all var(--transition);
  text-align: center;
  margin-top: var(--space-sm);
}
.sidebar-search-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }

@media (max-width: 900px) {
  .blog-layout { grid-template-columns: 1fr; }
  .blog-sidebar { position: static; }
}
</style>
