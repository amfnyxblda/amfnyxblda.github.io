---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import Pagination from '../../components/Pagination.astro';
import CategoryCloud from '../../components/CategoryCloud.astro';
import JSONLD from '../../components/JSONLD.astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  
  return paginate(allPosts, { pageSize: 5 });
}

// Fetch categories for the cloud on every paginated page
const allPosts = await getCollection('blog');
const allCategories = allPosts.map(post => post.slug.split('/')[0]);
const uniqueCategories = [...new Set(allCategories)];

const { page } = Astro.props;
const { data: paginatedPosts } = page;

const Schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Blog Posts - Page ${page.currentPage}`,
  "numberOfItems": page.total, // Total posts in the collection
  "itemListElement": page.data.map((post, index) => ({
    "@type": "ListItem",
    // Position should be relative to the current page (e.g., 11-20 on Page 2)
    "position": (page.currentPage - 1) * page.size + (index + 1),
    "url": new URL(`/blog/${post.slug}`, Astro.site).toString(),
    "name": post.data.title
  }))
};
---
<BaseLayout title={`My Astro Blog - Page ${page.currentPage}`} description="A blog about development and design">
  <JSONLD schema={Schema} slot="head" />
  <main>
    <h1>My Awesome Blog</h1>
    <p>Welcome! Here are my latest posts.</p>
    
    <CategoryCloud categories={uniqueCategories} activeCategory="all" />
    
    <PostList posts={paginatedPosts} />
    <Pagination page={page} />
  </main>
</BaseLayout>