---
import BaseLayout from "../layouts/BaseLayout.astro";
import RemoteMessageForm from "../components/RemoteMessageForm.astro";

const baseUrl = Astro.site?.toString() ?? Astro.url.origin;
const pageUrl = Astro.url.href;
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact - Jagapet",
  description: "Contact Jagapet for questions, suggestions, or collaboration.",
  url: pageUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "Jagapet",
    url: baseUrl,
  },
  about: {
    "@type": "Organization",
    name: "Jagapet",
    url: baseUrl,
  },
};
---

<BaseLayout
  title="Contact"
  description="Send us a message and we will get back to you."
>
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
  <section class="contact-page">
    <div class="container contact-page__inner">
      <span class="contact-page__kicker">Get in touch</span>
      <h1 class="contact-page__title">Contact</h1>
      <p class="contact-page__desc">
        Have a question, suggestion, or collaboration idea? Send us a note.
      </p>

      <RemoteMessageForm
        title="Send a Message"
        intro="Use the form below and we will reply as soon as we can."
        submitLabel="Send Message"
        source="contact-page"
        successMessage="Success. Your message has been received."
      />
    </div>
  </section>
</BaseLayout>

<style>
.contact-page {
  padding-top: calc(var(--nav-height) + var(--space-xl));
  padding-bottom: var(--space-3xl);
}

.contact-page__inner {
  max-width: 860px;
}

.contact-page__kicker {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: var(--space-sm);
}

.contact-page__title {
  margin: 0 0 var(--space-sm);
  font-size: clamp(2rem, 5vw, 3rem);
}

.contact-page__desc {
  margin: 0;
  max-width: 640px;
  color: var(--color-ink-3);
  line-height: 1.7;
}
</style>
